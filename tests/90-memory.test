# -*-Tcl-*-
# 90-memory.test — coarse leak probes (posix only, opt-in)
# Enable with: tclsh tests/all.tcl -constraints memory
package require tcltest 2.5
namespace import ::tcltest::*
source [file join [file dirname [info script]] 00-setup.test]

proc ::OratclTest::rss_kb {} {
    if {$::tcl_platform(platform) ne "unix"} {return -1}
    if {![llength [info commands exec]]} {return -1}
    set pid [pid]
    if {[catch {exec ps -o rss= -p $pid} out]} {return -1}
    set rss [string trim $out]
    if {![string is integer -strict $rss]} {return -1}
    return $rss
}

test 90-1.0 {open/close many statements RSS bounded} -constraints {have_connect posix memory} -body {
    ::OratclTest::with_connection L {
        set T0 [::OratclTest::rss_kb]
        for {set i 0} {$i < 500} {incr i} {
            set S [oraopen $L]
            oraparse $S {select 1 from dual}
            oraexec $S
            oraclose $S
        }
        set T1 [::OratclTest::rss_kb]
        expr {($T0 >= 0 && $T1 >= 0) ? ($T1 - $T0 < 20000) : 1}
    }
} -result 1

test 90-1.1 {array DML loops RSS bounded} -constraints {have_connect posix memory} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, name VARCHAR2(20))"]
        set T0 [::OratclTest::rss_kb]
        set S [oraopen $L]
        oraparse $S "INSERT INTO ${T}(id,name) VALUES (:id,:name)"
        for {set i 0} {$i < 50} {incr i} {
            set ids {}; set names {}
            for {set k 1} {$k <= 100} {incr k} {lappend ids $k; lappend names N$k}
            orabindexec $S -arraydml :id $ids :name $names -commit
        }
        oraclose $S
        set T1 [::OratclTest::rss_kb]
        expr {($T0 >= 0 && $T1 >= 0) ? ($T1 - $T0 < 40000) : 1}
    }
} -result 1

test 90-1.2 {repeated async exec RSS bounded} -constraints {have_connect posix memory} -body {
    ::OratclTest::with_connection L {
        set T0 [::OratclTest::rss_kb]
        set S [oraopen $L]
        oraparse $S "SELECT 1 FROM DUAL"
        for {set i 0} {$i < 200} {incr i} {
            oraexecasync $S
            orawaitasync $S -timeout 5000
        }
        oraclose $S
        set T1 [::OratclTest::rss_kb]
        expr {($T0 >= 0 && $T1 >= 0) ? ($T1 - $T0 < 20000) : 1}
    }
} -result 1

test 90-1.3 {repeated LOB handle open/close RSS bounded} -constraints {have_connect posix memory} -body {
    ::OratclTest::with_connection L {
        oraautocommit $L 0
        set T [::OratclTest::mk_table $L "(id NUMBER, c CLOB)" oratcl9_lmem]
        set S [oraopen $L]
        orasql $S "INSERT INTO ${T}(id,c) VALUES (1, 'test data')" -commit
        oraclose $S

        oraconfig $L inlineLobs 0
        set T0 [::OratclTest::rss_kb]
        for {set i 0} {$i < 200} {incr i} {
            set S [oraopen $L]
            orasql $S "SELECT c FROM ${T} WHERE id=1 FOR UPDATE"
            orafetch $S -datavariable row -indexbynumber
            oraclose $S
            set ch [lindex $row 0]
            oralob size $ch
            oralob close $ch
            oracommit $L
        }
        set T1 [::OratclTest::rss_kb]
        expr {($T0 >= 0 && $T1 >= 0) ? ($T1 - $T0 < 20000) : 1}
    }
} -result 1

test 90-1.4 {repeated connection open/close RSS bounded} -constraints {have_connect posix memory} -body {
    package require oratcl 9.0
    set cs [::OratclTest::connstr]
    set T0 [::OratclTest::rss_kb]
    for {set i 0} {$i < 50} {incr i} {
        set L [oralogon $cs]
        set S [oraopen $L]
        oraparse $S {select 1 from dual}
        oraexec $S
        oraclose $S
        oralogoff $L
    }
    set T1 [::OratclTest::rss_kb]
    expr {($T0 >= 0 && $T1 >= 0) ? ($T1 - $T0 < 30000) : 1}
} -result 1

cleanupTests
