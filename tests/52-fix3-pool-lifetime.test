# -*-Tcl-*-
# 52-fix3-pool-lifetime.test — pooled adopted connection lifetime
package require tcltest 2.5
namespace import ::tcltest::*
source [file join [file dirname [info script]] 00-setup.test]

test 52-1.0 {pooled connection basic lifecycle} \
    -constraints {have_connect} -body {
    package require oratcl 9.1
    set L [oralogon [::OratclTest::connstr] -pool 1 3 1]
    set S [oraopen $L]
    oraparse $S "SELECT 1 FROM DUAL"
    oraexec $S
    orafetch $S -datavariable row -indexbynumber
    set val [lindex $row 0]
    oraclose $S
    oralogoff $L
    set val
} -result 1

test 52-1.1 {adopter survives owner logoff on pooled connection} \
    -constraints {have_connect} -body {
    package require oratcl 9.1
    set L [oralogon [::OratclTest::connstr] -pool 1 3 1]
    set child [interp create]
    interp eval $child {package require oratcl 9.1}
    interp eval $child [list set L $L]
    interp eval $child {set S [oraopen $L]; oraclose $S}
    oralogoff $L
    set result [interp eval $child {
        set S [oraopen $L]
        oraparse $S {SELECT 42 FROM DUAL}
        oraexec $S
        orafetch $S -datavariable row -indexbynumber
        set val [lindex $row 0]
        oraclose $S; oralogoff $L
        set val
    }]
    interp delete $child
    set result
} -result 42

test 52-1.2 {multiple adopters survive owner logoff on pooled connection} \
    -constraints {have_connect} -body {
    package require oratcl 9.1
    set L [oralogon [::OratclTest::connstr] -pool 1 3 1]
    set children {}
    for {set i 0} {$i < 3} {incr i} {
        set child [interp create]
        interp eval $child {package require oratcl 9.1}
        interp eval $child [list set L $L]
        interp eval $child {set S [oraopen $L]; oraclose $S}
        lappend children $child
    }
    oralogoff $L
    set results {}
    foreach child $children {
        lappend results [interp eval $child {
            set S [oraopen $L]
            oraparse $S {SELECT 1 FROM DUAL}
            oraexec $S
            orafetch $S -datavariable row -indexbynumber
            set val [lindex $row 0]
            oraclose $S; oralogoff $L
            set val
        }]
        interp delete $child
    }
    set results
} -result {1 1 1}

test 52-2.0 {last adopter logoff closes pool cleanly} \
    -constraints {have_connect} -body {
    package require oratcl 9.1
    set L [oralogon [::OratclTest::connstr] -pool 1 2 1]
    set child [interp create]
    interp eval $child {package require oratcl 9.1}
    interp eval $child [list set L $L]
    interp eval $child {set S [oraopen $L]; oraclose $S}
    oralogoff $L
    interp eval $child {oralogoff $L}
    interp delete $child
    expr 1
} -result 1

test 52-3.0 {stress: 10 adopt/logoff cycles on pooled connection} \
    -constraints {have_connect} -body {
    package require oratcl 9.1
    set cs [::OratclTest::connstr]
    set ok 1
    for {set iter 0} {$iter < 10} {incr iter} {
        set L [oralogon $cs -pool 1 2 1]
        set child [interp create]
        interp eval $child {package require oratcl 9.1}
        interp eval $child [list set L $L]
        interp eval $child {
            set S [oraopen $L]
            oraparse $S {SELECT 1 FROM DUAL}
            oraexec $S; oraclose $S
        }
        oralogoff $L
        set res [interp eval $child {
            set S [oraopen $L]
            oraparse $S {SELECT 1 FROM DUAL}
            oraexec $S
            orafetch $S -datavariable row -indexbynumber
            set val [lindex $row 0]
            oraclose $S; oralogoff $L
            set val
        }]
        interp delete $child
        if {$res != 1} { set ok 0; break }
    }
    set ok
} -result 1

cleanupTests
