# -*-Tcl-*-
# 02-stmt-parse-exec-fetch.test — statement lifecycle, parse, exec, fetch options
package require tcltest 2.5
namespace import ::tcltest::*
source [file join [file dirname [info script]] 00-setup.test]

# ---- Statement handle lifecycle ----

test 02-1.0 {oraopen returns valid handle} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        set ok [string match "oraS*" $S]
        oraclose $S
        set ok
    }
} -result 1

test 02-1.1 {orastmt is alias of oraopen} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [orastmt $L]
        set ok [string match "oraS*" $S]
        oraclose $S
        set ok
    }
} -result 1

test 02-1.2 {oraclose on invalid handle errors} -constraints {have_connect} -body {
    package require oratcl 9.0
    catch {oraclose bogus_handle} msg
    string match "*invalid*" $msg
} -result 1

test 02-1.3 {double oraclose errors on second call} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        oraclose $S
        catch {oraclose $S} msg
        string match "*invalid*" $msg
    }
} -result 1

test 02-1.4 {multiple statements on same connection} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S1 [oraopen $L]
        set S2 [oraopen $L]
        set S3 [oraopen $L]
        oraclose $S1
        oraclose $S2
        oraclose $S3
        expr {$S1 ne $S2 && $S2 ne $S3}
    }
} -result 1

# ---- oraparse ----

test 02-2.0 {oraparse basic} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        oraparse $S "select 1 from dual"
        oraclose $S
        expr 1
    }
} -result 1

test 02-2.1 {oraparse with invalid SQL errors at parse time} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        set rc [catch {oraparse $S "SELECTX INVALID"} msg]
        oraclose $S
        expr {$rc == 1}
    }
} -result 1

test 02-2.2 {re-parse on same handle replaces statement} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        ::OratclTest::insert_rows $L $T 3
        set S [oraopen $L]
        oraparse $S "SELECT id FROM $T WHERE id=1"
        oraexec $S
        orafetch $S -datavariable r1 -indexbynumber
        # Re-parse different query
        oraparse $S "SELECT id FROM $T WHERE id=2"
        oraexec $S
        orafetch $S -datavariable r2 -indexbynumber
        oraclose $S
        list [lindex $r1 0] [lindex $r2 0]
    }
} -result {1 2}

# ---- orasql ----

test 02-3.0 {orasql convenience parse+exec} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER)"]
        set S [oraopen $L]
        set rc [orasql $S "INSERT INTO $T VALUES (1)" -commit]
        oraclose $S
        set rc
    }
} -result 0

test 02-3.1 {orasql -parseonly does not execute} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER)"]
        set S [oraopen $L]
        orasql $S "INSERT INTO $T VALUES (99)" -parseonly
        # Row should not exist since we only parsed
        oracommit $L
        oraclose $S
        ::OratclTest::count_rows $L $T
    }
} -result 0

# ---- oraplexec ----

test 02-3.2 {oraplexec PL/SQL block} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        set rc [oraplexec $S {begin null; end;} -commit]
        oraclose $S
        set rc
    }
} -result 0

# ---- oraexec ----

test 02-4.0 {oraexec without prior parse errors} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        set rc [catch {oraexec $S} msg]
        oraclose $S
        expr {$rc == 1}
    }
} -result 1

test 02-4.1 {oraexec -commit} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER)"]
        set S [oraopen $L]
        oraparse $S "INSERT INTO $T VALUES (1)"
        oraexec $S -commit
        oraclose $S
        ::OratclTest::count_rows $L $T "id=1"
    }
} -result 1

# ---- orafetch modes ----

test 02-5.0 {orafetch default returns 0/1403 status} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT 1 FROM DUAL"
        set rc1 [orafetch $S]
        set rc2 [orafetch $S]
        oraclose $S
        list $rc1 $rc2
    }
} -result {0 1403}

test 02-5.1 {orafetch -returnrows returns list} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        ::OratclTest::insert_rows $L $T 3
        set S [oraopen $L]
        orasql $S "SELECT id, val FROM $T ORDER BY id"
        set rows [orafetch $S -returnrows]
        oraclose $S
        llength $rows
    }
} -result 3

test 02-5.2 {orafetch -max limits rows} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        ::OratclTest::insert_rows $L $T 10
        set S [oraopen $L]
        orasql $S "SELECT id FROM $T ORDER BY id"
        set batch [orafetch $S -returnrows -max 3]
        oraclose $S
        llength $batch
    }
} -result 3

test 02-5.3 {orafetch -datavariable} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT 42 AS answer FROM DUAL"
        set rc [orafetch $S -datavariable row -indexbynumber]
        oraclose $S
        list $rc [lindex $row 0]
    }
} -result {0 42}

test 02-5.4 {orafetch -asdict returns dict keyed by column names} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT 1 AS A, 2 AS B FROM DUAL"
        set rc [orafetch $S -asdict -datavariable row]
        oraclose $S
        list $rc [dict get $row A] [dict get $row B]
    }
} -result {0 1 2}

test 02-5.5 {orafetch -resultvariable with -max iteration} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        ::OratclTest::insert_rows $L $T 5
        set S [oraopen $L]
        orasql $S "SELECT id FROM $T ORDER BY id"
        set all {}
        while 1 {
            set rc [orafetch $S -resultvariable batch -max 2]
            foreach r $batch { lappend all $r }
            if {$rc == 1403} break
        }
        oraclose $S
        llength $all
    }
} -result 5

test 02-5.6 {orafetch -command executes script per row} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        ::OratclTest::insert_rows $L $T 3
        set S [oraopen $L]
        orasql $S "SELECT id FROM $T ORDER BY id"
        set collected {}
        orafetch $S -datavariable row -indexbynumber -command {
            lappend collected [lindex $row 0]
        }
        oraclose $S
        set collected
    }
} -result {1 2 3}

test 02-5.7 {orafetch -dataarray -indexbyname} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT 10 AS X, 20 AS Y FROM DUAL"
        orafetch $S -dataarray arr -indexbyname
        oraclose $S
        list $arr(X) $arr(Y)
    }
} -result {10 20}

test 02-5.8 {orafetch -dataarray -indexbynumber} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT 10 AS X, 20 AS Y FROM DUAL"
        orafetch $S -dataarray arr -indexbynumber
        oraclose $S
        list $arr(0) $arr(1)
    }
} -result {10 20}

test 02-5.9 {orafetch on empty result returns 1403} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER)"]
        set S [oraopen $L]
        orasql $S "SELECT id FROM $T"
        set rc [orafetch $S]
        oraclose $S
        set rc
    }
} -result 1403

test 02-5.10 {fetch without execute errors} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        oraparse $S "SELECT 1 FROM DUAL"
        # Don't exec — fetch should error
        set rc [catch {orafetch $S} msg]
        oraclose $S
        expr {$rc == 1}
    }
} -result 1

# ---- oracols ----

test 02-6.0 {oracols returns column metadata} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, name VARCHAR2(50))"]
        set S [oraopen $L]
        orasql $S "SELECT id, name FROM $T"
        set cols [oracols $S]
        oraclose $S
        list [dict get [lindex $cols 0] name] [dict get [lindex $cols 1] name]
    }
} -result {ID NAME}

# ---- oradesc ----

test 02-7.0 {oradesc returns column info} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, name VARCHAR2(50))"]
        set desc [oradesc $L $T]
        expr {[llength $desc] >= 2}
    }
} -result 1

# ---- Data types ----

test 02-8.0 {NULL values fetched correctly} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val VARCHAR2(20))"]
        set S [oraopen $L]
        orasql $S "INSERT INTO $T VALUES (1, NULL)" -commit
        orasql $S "SELECT val FROM $T WHERE id=1"
        orafetch $S -datavariable row -indexbynumber
        oraclose $S
        # NULL should come back as empty string
        expr {[lindex $row 0] eq ""}
    }
} -result 1

test 02-8.1 {DATE type roundtrip} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set S [oraopen $L]
        orasql $S "SELECT TO_CHAR(SYSDATE, 'YYYY') FROM DUAL"
        orafetch $S -datavariable row -indexbynumber
        oraclose $S
        # Should be a 4-digit year
        string is integer -strict [lindex $row 0]
    }
} -result 1

test 02-8.2 {unicode data roundtrip} -constraints {have_connect} -body {
    ::OratclTest::with_connection L {
        set T [::OratclTest::mk_table $L "(id NUMBER, val NVARCHAR2(100))"]
        set S [oraopen $L]
        set input "café résumé naïve"
        oraparse $S "INSERT INTO $T VALUES (1, :v)"
        orabind $S :v $input
        oraexec $S -commit
        oraparse $S "SELECT val FROM $T WHERE id=1"
        oraexec $S
        orafetch $S -datavariable row -indexbynumber
        oraclose $S
        expr {[lindex $row 0] eq $input}
    }
} -result 1

cleanupTests
